# infra-26 deployment config. Copy to `.env` and adjust.
# `deploy.sh` substitutes these into the manifests with envsubst.

# ── Domains (must resolve to this VPS via DNS A/AAAA records) ──────────────────
DOMAIN=book.holtz.fr            # photo-book (and /db → adminer)
PLAY_DOMAIN=play.holtz.fr       # mine-sim
APP_DOMAIN=app.holtz.fr         # small apps: /getaround
ADMIN_DOMAIN=admin.holtz.fr     # admin surface: /portainer + /grafana

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
ACME_EMAIL=noname@book.holtz.fr

# ── Images (Docker Hub) ───────────────────────────────────────────────────────
PHOTO_IMAGE=jarod68/photo-book:latest
MINESIM_IMAGE=jarod68/mine-sim:latest
GETAROUND_IMAGE=jarod68/getaround-scraper:latest

# ── Docker Hub pull credentials (GETAROUND_IMAGE is a PRIVATE repo) ───────────
# Use a read-only access token (hub.docker.com → Account Settings → Security).
# Needed on first deploy; afterwards the created secret is reused if left blank.
DOCKERHUB_USER=jarod68
DOCKERHUB_TOKEN=

# ── Optional: Web Push for photo-book ─────────────────────────────────────────
# Leave blank to disable push. If set, they are stored in the app-secrets Secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noname@book.holtz.fr

# MINESIM_WORKERS is computed from the host CPU count by deploy.sh (1 ⇒ single
# process). Override here only if you want to pin it.
# MINESIM_WORKERS=1
